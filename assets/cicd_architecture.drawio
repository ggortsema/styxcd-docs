<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="CI/CD Architecture">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="github" value="GitHub (Source Control)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="api" value="API Gateway (Webhook)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="60" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="jenkins" value="Jenkins (EC2 Runtime)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="60" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="engine" value="Pipeline Engine (YAML + IoC)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="60" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="stages" value="Stage Execution (Compute Layer)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="180" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="obs" value="Observability (Splunk / Dashboard)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="300" width="240" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="github" target="api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="api" target="jenkins">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="jenkins" target="engine">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="engine" target="stages">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="stages" target="obs">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
